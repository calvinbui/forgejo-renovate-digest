# Forgejo instance URL (no trailing slash)
FORGEJO_URL=https://forgejo.example.com

# API token — generate one at: <your-instance>/user/settings/applications
FORGEJO_TOKEN=your_api_token_here

# Repository in owner/repo format
FORGEJO_REPO=myorg/myrepo

# SMTP settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your_smtp_password

# Set to "false" to disable STARTTLS (not recommended)
SMTP_TLS=true

# Email addresses
EMAIL_FROM=alerts@example.com
EMAIL_TO=team@example.com
